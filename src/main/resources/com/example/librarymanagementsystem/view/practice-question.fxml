<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: transparent;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.librarymanagementsystem.controller.PracticeQuestionController">
    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <Label fx:id="lblSubject" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label fx:id="lblQuestion" wrapText="true" textAlignment="CENTER" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 20; -fx-text-fill: #00dbde;"/>

    <VBox spacing="15" alignment="CENTER" maxWidth="600">
        <Button fx:id="btnA" onAction="#checkAnswer" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
        <Button fx:id="btnB" onAction="#checkAnswer" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
        <Button fx:id="btnC" onAction="#checkAnswer" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
        <Button fx:id="btnD" onAction="#checkAnswer" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
    </VBox>

    <Region prefHeight="20"/>

    <Button fx:id="btnNext" text="Next Question" onAction="#loadNextQuestion" visible="false" style="-fx-background-color: linear-gradient(to right, #4facfe, #00f2fe); -fx-text-fill: #1a2a6c; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 10 30; -fx-background-radius: 20; -fx-cursor: hand;"/>
</VBox>