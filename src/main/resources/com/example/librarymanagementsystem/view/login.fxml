<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: #000000;"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.librarymanagementsystem.controller.LoginController">

    <VBox alignment="CENTER" spacing="30" maxWidth="450" maxHeight="500"
          style="-fx-background-color: rgba(255, 255, 255, 0.05);
                 -fx-background-radius: 25;
                 -fx-border-color: linear-gradient(to bottom right, #fc00ff, #00dbde);
                 -fx-border-width: 3;
                 -fx-border-radius: 25;
                 -fx-padding: 50;
                 -fx-effect: dropshadow(gaussian, rgba(0, 219, 222, 0.4), 25, 0, 0, 0);">

        <Label fx:id="titleLabel" text="Portal Login"
               style="-fx-text-fill: #f8b500; -fx-font-size: 36px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(248,181,0,0.5), 10, 0, 0, 0);"/>

        <VBox spacing="20" alignment="CENTER">
            <TextField fx:id="usernameField" promptText="Enter Username" styleClass="text-field" prefHeight="45" style="-fx-font-size: 16px;"/>
            <PasswordField fx:id="passwordField" promptText="Enter Password" styleClass="text-field" prefHeight="45" style="-fx-font-size: 16px;"/>
        </VBox>

        <HBox spacing="20" alignment="CENTER">
            <Button text="Login" onAction="#handleLogin" styleClass="button" prefWidth="150" prefHeight="45" style="-fx-font-size: 18px;"/>
            <Button fx:id="btnSignUp" text="Sign Up" onAction="#handleSignUp" styleClass="button" prefWidth="150" prefHeight="45" style="-fx-font-size: 18px;"/>
        </HBox>

        <Button text="← Back to Welcome" onAction="#goBackToWelcome" styleClass="button-back" prefWidth="200" style="-fx-background-color: transparent; -fx-text-fill: #00dbde; -fx-border-color: #00dbde; -fx-border-radius: 30;"/>

    </VBox>
</StackPane>