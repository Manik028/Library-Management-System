<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #000000; -fx-padding: 50;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.librarymanagementsystem.controller.CreateQuestionController">

    <Label fx:id="lblSubject" text="Create Question"
           style="-fx-text-fill: #f8b500; -fx-font-size: 32px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(248,181,0,0.5), 10, 0, 0, 0);"/>

    <TextArea fx:id="txtQuestion" promptText="Enter the question here..." prefHeight="100" styleClass="text-field" wrapText="true"/>

    <TextField fx:id="txtOptA" promptText="Option A" styleClass="text-field"/>
    <TextField fx:id="txtOptB" promptText="Option B" styleClass="text-field"/>
    <TextField fx:id="txtOptC" promptText="Option C" styleClass="text-field"/>
    <TextField fx:id="txtOptD" promptText="Option D" styleClass="text-field"/>

    <HBox spacing="15" alignment="CENTER">
        <Label text="Correct Answer:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;"/>
        <ComboBox fx:id="comboCorrect" styleClass="combo-box" prefWidth="100">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="A"/>
                    <String fx:value="B"/>
                    <String fx:value="C"/>
                    <String fx:value="D"/>
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <Button text="Save Question" onAction="#saveQuestion" styleClass="button" prefWidth="250" prefHeight="45"/>

</VBox>