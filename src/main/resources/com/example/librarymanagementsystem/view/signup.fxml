<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: #0f0c29;" stylesheets="@../style/style.css" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.librarymanagementsystem.controller.SignupController">
    <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>

    <Label text="User Registration" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #00dbde;"/>

    <TextField fx:id="txtUsername" promptText="Choose a Username" maxWidth="300"/>
    <PasswordField fx:id="txtPassword" promptText="Choose a Password" maxWidth="300"/>
    <TextField fx:id="txtFullName" promptText="Full Name (For ID Card)" maxWidth="300"/>

    <DatePicker fx:id="dpDOB" promptText="Date of Birth" maxWidth="300" style="-fx-font-size: 14px;"/>
    <TextField fx:id="txtStudentId" promptText="Student ID Number" maxWidth="300"/>

    <HBox spacing="10" alignment="CENTER" maxWidth="300">
        <Button text="Select Photo" onAction="#choosePhoto" style="-fx-background-color: #fc00ff; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Label fx:id="lblPhotoPath" text="No file selected" style="-fx-text-fill: lightgray; -fx-font-size: 12px;" wrapText="true" maxWidth="150"/>
    </HBox>

    <Region prefHeight="10"/>

    <Button text="Create Account &amp; Generate Card" onAction="#registerUser" style="-fx-background-color: #00dbde; -fx-text-fill: #0f0c29; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 10 20;"/>
    <Button text="Cancel" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #ff4c4c; -fx-underline: true;"/>
</VBox>