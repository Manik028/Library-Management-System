<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="500" prefWidth="800" spacing="10" style="-fx-background-color: transparent;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.librarymanagementsystem.controller.ChatController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <VBox fx:id="userListContainer" spacing="10" prefWidth="200" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 15; -fx-padding: 10;">
        <Label text="Contacts" style="-fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>
        <ListView fx:id="listUsers" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;"/>
    </VBox>

    <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 15; -fx-padding: 15;">
        <Label fx:id="lblChatHeader" text="Select a contact to start" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>

        <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: white; -fx-border-color: #cccccc;">
            <VBox fx:id="chatBox" spacing="10" style="-fx-padding: 10;"/>
        </ScrollPane>

        <HBox spacing="10">
            <TextField fx:id="txtMessage" promptText="Type a message..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 20;"/>
            <Button text="Send" onAction="#sendMessage" style="-fx-background-color: #1a2a6c; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20;"/>
        </HBox>
    </VBox>
</HBox>