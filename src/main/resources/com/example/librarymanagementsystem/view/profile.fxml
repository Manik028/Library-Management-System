<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #000000; -fx-padding: 40;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.librarymanagementsystem.controller.ProfileController">

    <Label text="User Profile" style="-fx-text-fill: #f8b500; -fx-font-size: 32px; -fx-font-weight: bold;"/>

    <StackPane maxWidth="130" maxHeight="130" style="-fx-border-color: #f8b500; -fx-border-width: 3; -fx-border-radius: 100; -fx-background-radius: 100; -fx-overflow: hidden;">
        <ImageView fx:id="imgProfilePreview" fitWidth="120" fitHeight="120" preserveRatio="false"/>
    </StackPane>
    <Button text="Change Photo" onAction="#chooseNewPhoto" style="-fx-background-color: transparent; -fx-text-fill: #00dbde; -fx-cursor: hand;"/>

    <GridPane vgap="15" hgap="20" alignment="CENTER">
        <Label text="Full Name:" style="-fx-text-fill: white;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtFullName" styleClass="text-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Student ID:" style="-fx-text-fill: white;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtStudentId" styleClass="text-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Birth Date:" style="-fx-text-fill: white;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpDOB" prefWidth="200" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="New Password:" style="-fx-text-fill: white;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <PasswordField fx:id="txtPassword" styleClass="text-field" promptText="Leave blank to keep old" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="20" alignment="CENTER">
        <Button text="Save Changes" onAction="#handleSave" style="-fx-background-color: #f8b500; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 30;"/>
        <Button text="← Back" onAction="#backToDashboard" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 30;"/>
    </HBox>
</VBox>