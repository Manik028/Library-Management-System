<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.librarymanagementsystem.controller.ReportController"
      style="-fx-padding: 20; -fx-background-color: linear-gradient(to bottom, #1E3C72, #2A5298);">

    <!-- Top bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Back" onAction="#backToDashboard"
                style="-fx-background-color: #ffffff; -fx-text-fill: #2A5298; -fx-font-weight: bold;"/>
        <Label text="Reports  Statistics"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <!-- Statistics Labels -->
    <HBox spacing="30" alignment="CENTER">
        <VBox spacing="5" alignment="CENTER">
            <Label text="Total Books Issued" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <Label fx:id="totalBooksIssued" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Active Members" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <Label fx:id="activeMembers" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Overdue Books" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <Label fx:id="overdueBooks" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
        </VBox>
    </HBox>

    <!-- Charts -->
    <HBox spacing="30" alignment="CENTER">
        <BarChart fx:id="barChart" title="Books Issued Per Month" prefWidth="400" prefHeight="300">
            <xAxis>
                <CategoryAxis label="Month"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Books Issued"/>
            </yAxis>
        </BarChart>

        <PieChart fx:id="pieChart" title="Issued vs Available Books" prefWidth="400" prefHeight="300"/>
    </HBox>
</VBox>